# ============================================================
# AI 作家委员会 - 环境变量模板
# 使用方式：复制本文件为 .env，填入真实的 API key
#   cp .env.example .env
# .env 已在 .gitignore 中，不会进入版本控制
# ============================================================

# ── Claude (Anthropic) ──────────────────────────────────────
# 主编 / 作家 / 批评家 默认使用此模型
ANTHROPIC_API_KEY=
# BASE_URL 留空或保持默认值则使用官方地址
# 如需使用自选代理，将下方地址替换为代理地址
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── DeepSeek ────────────────────────────────────────────────
# 一致性委员 / 润色师 默认使用此模型（成本优化）
DEEPSEEK_API_KEY=
# BASE_URL 留空或保持默认值则使用官方地址
# 如需使用自选代理，将下方地址替换为代理地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Gemini（备用，暂无委员岗位）────────────────────────────
# MVP 阶段暂未分配委员岗位，接口已预留，可不填
GEMINI_API_KEY=
# BASE_URL 留空或保持默认值则使用官方地址
# 如需使用自选代理，将下方地址替换为代理地址
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── 服务器配置 ───────────────────────────────────────────────
# 本地访问，不对外暴露；如需局域网访问可改为 0.0.0.0（注意安全风险）
HOST=127.0.0.1
PORT=8000
